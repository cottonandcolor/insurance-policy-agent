LLM_PROVIDER=ollama
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# Optional OpenAI fallback:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

CHROMA_PERSIST_DIR=data/chroma
POLICY_DATA_DIR=data/synthetic
UPLOAD_DIR=data/uploads

# Free cloud (open models) via Groq — OpenAI-compatible, no credit card:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=gsk_your_groq_key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Other free/low-cost OpenAI-compatible hosts (same vars, change URL + model):
# OpenRouter free models: https://openrouter.ai/api/v1  (e.g. meta-llama/llama-3.3-70b-instruct:free)
# Together AI: https://api.together.xyz/v1

# Slow free models: increase read timeout (seconds) and retries for notebook/API live runs
# LLM_READ_TIMEOUT=600
# LLM_MAX_RETRIES=3
